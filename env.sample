# ── Airflow ────────────────────────────────────────────────────────────────────

# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=REPLACE_WITH_GENERATED_FERNET_KEY

# Generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_SECRET_KEY=REPLACE_WITH_GENERATED_SECRET_KEY

# Run: echo "AIRFLOW_UID=$(id -u)" in your terminal and paste result below
# Windows users: leave as 50000
AIRFLOW_UID=50000

# ── GCP ────────────────────────────────────────────────────────────────────────

GCP_PROJECT_ID=my-gcp-project-id
GCS_BUCKET_NAME=my-gcs-bucket-name

# ── Pipeline ───────────────────────────────────────────────────────────────────

# Use "gcs" inside Docker — "local" is only for running python/ scripts directly
STORAGE_BACKEND=gcs

# ── API Keys ───────────────────────────────────────────────────────────────────

COINGECKO_API_KEY=my-coingecko-api-key
NEWS_API_KEY=my-newsapi-api-key
