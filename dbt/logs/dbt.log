  create or replace view `crypto-analytics-2026`.`crypto_analytics_dev_marts_crypto_staging`.`stg_crypto_news`
  OPTIONS()
  as 

with sources as (
    select * from `crypto-analytics-2026`.`crypto_analytics_dev_raw`.`news`
),

staged as (
    select
      --- Key ---------------------
      to_hex(md5(cast(coalesce(cast(coin as string), '_dbt_utils_surrogate_key_null_') || '-' || coalesce(cast(url_hash as string), '_dbt_utils_surrogate_key_null_') as string))) as news_id,

      ---- dimension---------------
      cast(coin as string) as coin,
      cast(published_at as timestamp) as published_at,
      cast(keyword as string) as keyword,

      ----- metadata ---------------
      cast(source_name as string) as source_name,
      cast(description as string) as description,
      cast(author as string) as author,
      cast(title as string) as title,
      cast(url_hash as string) as url_hash,
      cast(ingested_at as timestamp) as ingested_at,

      ----- metrics -----------------
      cast(sentiment_compound as float64) as sentiment_compound,
      cast(sentiment_positive as float64) as sentiment_positive,
      cast(sentiment_negative as float64) as sentiment_negative,
      cast(sentiment_neutral as float64) as sentiment_neutral,
      cast(sentiment_label as string) as sentiment_label
    
    from sources
    where coin is not null and published_at is not null
)

select * from staged;


